# Cloud LLM API key (required when use_mock: false in configs/llm.yaml)
OPENAI_API_KEY=sk-your-openai-key-here

# Alternative: Anthropic (set cloud.provider: anthropic in configs/llm.yaml)
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# Device LLM runs locally — no API key needed for Ollama/vLLM
# Ensure Ollama is running: ollama serve
# Or vLLM: python -m vllm.entrypoints.openai.api_server --model meta-llama/Llama-3.1-8B-Instruct
